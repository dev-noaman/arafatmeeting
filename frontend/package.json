    "axios": "^1.13.4",
    "livekit-client": "^2.17.0",
    "lucide-react": "^0.564.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "react-router-dom": "^7.13.0",
    "react-use-websocket": "^4.13.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
